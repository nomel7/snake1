{
  "name": "snake-animation",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "Animated, color-shifting snakes that trace Lissajous paths across an HTML canvas. React + TypeScript + Vite.",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "vite build && aws s3 cp dist/index.html s3://snake-animation-kdone-2026/index.html",
    "ts-node": "^10.9.0"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/lib-storage": "^3.600.0",
    "mime-types": "^2.1.35",
    "@types/mime-types": "^2.1.4"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-singlefile": "^2.0.0",
    "vitest": "^1.6.0"
  }

}
